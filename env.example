# PostgreSQL/PostGIS connection string
DATABASE_URL=postgresql://user:password@host:5432/vetector

# Server
PORT=3000
NODE_ENV=production

# CORS, comma-separated. Use * for public demo.
CORS_ORIGIN=https://vet.ector.nibbiotec.com,http://localhost:5173,http://localhost:3000

# Query defaults and limits
DEFAULT_RADIUS_KM=50
MAX_RADIUS_KM=250
DEFAULT_DAYS=180
MAX_DAYS=730
MAX_RESULTS=1000
